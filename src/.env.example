# === Database Configuration ===
DB_NAME=journi_db
DB_USER=journi_user
DB_PASSWORD=journi_password

# === Spring Boot Database Config ===
SPRING_DB_URL=jdbc:postgresql://database:5432/journi_db

# === Redis Configuration ===
REDIS_HOST=cache
REDIS_PORT=6379

# Separate non-production bootstrap key required only because the worker reuses the backend module.
# Generate with: openssl rand -base64 32
GRADER_BOOTSTRAP_SECRET=replace_with_a_separate_base64_encoded_32_byte_secret

# Backend auth/session settings live in src/backend/.env. Copy
# src/backend/.env.example to src/backend/.env before starting Docker Compose.
