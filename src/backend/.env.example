# Base64-encoded key with at least 256 bits of entropy. Generate one with:
# openssl rand -base64 32
JWT_SECRET_KEY=replace_with_a_base64_encoded_32_byte_secret

# Authentication session lifetimes use java.time.Duration syntax.
ACCESS_TOKEN_LIFETIME=PT15M
REFRESH_TOKEN_LIFETIME=P30D

# Keep Secure=false only for local HTTP. Production HTTPS must use true.
REFRESH_COOKIE_NAME=journi_refresh
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAME_SITE=Lax

CSRF_COOKIE_NAME=journi_csrf
CSRF_HEADER_NAME=X-CSRF-TOKEN

# Comma-separated exact origins; do not use * with credentialed requests.
FRONTEND_ALLOWED_ORIGINS=http://localhost:3000

# Optional read-only token for higher GitHub API rate limits. Leave empty for public anonymous access.
PRACTICE_GITHUB_TOKEN=
PRACTICE_SUBMISSIONS_ENABLED=false

# Redis Stream delivery and worker recovery.
PRACTICE_SUBMISSION_STREAM=practice-submissions
PRACTICE_SUBMISSION_CONSUMER_GROUP=practice-graders
PRACTICE_SUBMISSION_POLL_DELAY_MS=1000
PRACTICE_SUBMISSION_RECOVERY_DELAY_MS=60000
PRACTICE_GRADER_LEASE_DURATION=PT10M

# Isolated workspace, repository, result, and process limits.
PRACTICE_GRADER_CLONE_TIMEOUT=PT1M
PRACTICE_GRADER_MAX_REPOSITORY_BYTES=52428800
PRACTICE_GRADER_MAX_OUTPUT_BYTES=32768
PRACTICE_GRADER_MAX_RESULT_BYTES=65536
PRACTICE_GRADER_CPUS=1.0
PRACTICE_GRADER_MEMORY=768m
PRACTICE_GRADER_PIDS_LIMIT=128
PRACTICE_GRADER_CONCURRENCY=1
